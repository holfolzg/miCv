---
import { education, certificates } from "@cv"
import Section from "../Section.astro"
---

<Section title="Educación">
  <ul>
    {
      education.map(({ area, institution, startDate, endDate, studyType }) => {
        return (
          <li>
            <article>
              <header>
                <div>
                    <h3>{area}</h3>
                    <h4>{institution}</h4>
                </div>
                <time>{startDate} — {endDate}</time>
              </header>
              <footer>
                <span>{studyType}</span>
              </footer>
            </article>
          </li>
        )
      })
    }
  </ul>
</Section>
<Section title="Certificados">
    <ul>
        {
      certificates.map(({ name, issuer, date, url, codigo }) => {
        return (
          <li>
            <article>
              <header>
                <a href={url} title={`Ver certificado ${name}`} target="_blank">
                  <h3>{name}</h3>
                </a>
                <p>Emisor: {issuer}</p>
              </header>
              <footer class="cert-footer">
                <time>{date}</time>
                {codigo && <span class="code">Cod: {codigo}</span>}
              </footer>
            </article>
          </li>
        )
      })
    }
    </ul>
</Section>

<style>
  ul {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
  }

  article {
    border-radius: 8px;
    border: 1px solid #d8d8d8;
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 16px;
    height: 100%;
    transition: all 0.3s ease;
  }

  article:hover {
    border-color: #111;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.05);
  }

  header {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #111;
  }

  h4 {
    font-size: 0.85rem;
    color: #444;
    font-weight: 500;
  }

  time {
    font-size: 0.75rem;
    color: #666;
  }

  article p {
    font-size: 0.75rem;
    color: #666;
    margin-top: 4px;
  }

  footer {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: auto;
  }

  footer span {
    border-radius: 6px;
    background: #eee;
    color: #333;
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
  }

  .code {
    background: #f0f0f0;
    font-family: monospace;
    font-size: 0.6rem;
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  a:hover h3 {
    text-decoration: underline;
    color: #000;
  }
</style>