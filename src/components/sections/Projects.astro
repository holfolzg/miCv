---
import { projects } from "@cv"
import Section from "../Section.astro"
---

<Section title="Proyectos">
    <ul>
        {
            projects.map(({ url, description, highlights, name, isActive }) => {
                return (
                    <li>
                        <article>
                            <header>
                                <a href={url} title={`Ver el proyecto ${name}`} target="_blank"> <h3>{name}</h3></a>
                                <p>{description}</p>

                            </header>
                            <footer>
                                {
                                  highlights.map((highlight) => {
                                    return <span>{highlight}</span>
                                  })
                                }
                            </footer>
                        </article>
                    </li>
                )
            })
        }
    </ul>

</Section>

<style>
    ul {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
    }

    article {
        border-radius: 8px;
        border: 1px solid #d8d8d8;
        gap: 16px;
        display: flex;
        flex-direction: column ;
        padding: 16px;
        height: 100%;
    }

    footer {
        display: flex;
        flex-wrap: wrap;
        font-size: 0.6rem;
        gap: 4px;
    }

    footer span {
        border-radius: 6px;
        background: #d8d8d8;
        color: #333;
        font-size: 0.6rem;
        font-weight: 500;
        padding: 0.2rem 0.6rem;
    }

    article h3{
        margin-bottom: 4px;
    }

    article a {
        color: #111;
    }

    article:hover {
        text-decoration: underline;
    }

    article p {
        font-size: 0.7rem;
        line-height: 1.1rem;
        margin-bottom: 8px;i
    }
</style>