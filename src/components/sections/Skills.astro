---
import { skills } from "@cv"
import Section from "../Section.astro"
---

<Section title="Habilidades">
    <ul>
        {skills.map(({ name }) => (
            <li>
                <span>{name}</span>
            </li>
        ))
        }
    </ul>

</Section>

<style>
    ul {
        display: inline-flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    li {
        border-radius: 6px;
        background: #d8d8d8;
        color: black;
        font-size: .8rem;
        font-weight: 500;
        padding: 0.2rem;
    }
</style>